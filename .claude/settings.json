{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(grep:*)",
      "Bash(git:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cd:*)",
      "Bash(mkdir:*)",
      "Bash(find:*)",
      "Bash(echo:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(which:*)",
      "Bash(node:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)"
    ],
    "deny": [
      "Bash(*rm*)",
      "Bash(*dd:*)",
      "Bash(*mkfs:*)",
      "Bash(*chmod:*)",
      "Bash(*chown:*)",
      "Bash(*kill*)",
      "Bash(*sudo*)",
      "Bash(*|*sudo*)",
      "Bash(*&&*sudo*)",
      "Bash(*;*sudo*)",
      "Bash(*||*sudo*)",
      "Bash(*curl*|*sh*)",
      "Bash(*curl*|*bash*)",
      "Bash(*wget*|*sh*)",
      "Bash(*wget*|*bash*)",
      "Bash(*curl*bash*)",
      "Bash(*wget*bash*)",
      "Bash(*systemctl:*)",
      "Bash(*reboot*)",
      "Bash(*shutdown:*)",
      "Bash(*eval:*)",
      "Bash(*exec:*)",
      "Bash(*vi:*)",
      "Bash(*vim:*)",
      "Bash(*nano:*)",
      "Bash(*\\$(*)*)",
      "Bash(*`*`*)",
      "Bash(*|*rm*)",
      "Bash(*&&*rm*)",
      "Bash(*;*rm*)",
      "Bash(*||*rm*)",
      "Bash(*rm*|*)",
      "Bash(*rm*&&*)",
      "Bash(*rm*;*)",
      "Bash(*rm*||*)",
      "Bash(*&*rm*)",
      "Bash(*|*dd*)",
      "Bash(*|*chmod*)",
      "Bash(*|*chown*)",
      "Bash(*|*kill*)",
      "Bash(*format*)",
      "Bash(*partition*)",
      "Bash(*truncate*)",
      "Bash(*poweroff*)",
      "Bash(*halt*)",
      "Bash(*source*/*)",
      "Bash(*.*rc*)",
      "Bash(*./*)",
      "Bash(*/.*)"
    ]
  },

  "model": "sonnet",
  "env": {
    "MAX_THINKING_TOKENS": "10000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50"
  }
}

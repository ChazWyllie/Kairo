generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Member {
  id               String   @id @default(cuid())
  email            String   @unique
  phone            String?
  stripeCustomerId String?  @unique
  stripeSubId      String?  @unique
  status           String   @default("pending") // pending | active | canceled

  // Multi-tier pricing (Phase 7+)
  planTier         String?  // "foundation" | "coaching" | "performance" | "vip"
  billingInterval  String?  // "monthly" | "annual"

  // Onboarding (Phase 4) — all optional, filled post-checkout
  goal             String?  // "fat_loss" | "muscle" | "maintenance"
  daysPerWeek      Int?     // 1-7
  minutesPerSession Int?    // 15 | 20 | 30 | 45 | 60
  injuries         String?  // free-text limitations
  onboardedAt      DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  checkIns         CheckIn[]
}

model StripeEvent {
  id        String   @id // Stripe event id
  createdAt DateTime @default(now())
}

model CheckIn {
  id        String   @id @default(cuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id])
  date      DateTime @db.Date // one check-in per day

  workout   Boolean  @default(false)
  meals     Int      @default(0) // 0-3 meals logged
  water     Boolean  @default(false)
  steps     Boolean  @default(false)
  note      String?  // optional "I missed because…"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([memberId, date])
  @@index([memberId, date(sort: Desc)])
}

model Lead {
  id              String   @id @default(cuid())
  email           String   @unique
  quizAnswers     Json?    // stored quiz answers
  recommendedTier String?  // tier recommended by quiz engine
  source          String   @default("quiz") // "quiz" | "waitlist" | etc.
  capturedAt      DateTime @default(now())
  convertedAt     DateTime? // set when lead becomes a paying member

  @@index([email])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Member {
  id               String   @id @default(cuid())
  email            String   @unique
  phone            String?
  stripeCustomerId String?  @unique
  stripeSubId      String?  @unique
  status           String   @default("pending") // pending | active | canceled

  // Multi-tier pricing (Phase 7+)
  planTier         String?  // "foundation" | "coaching" | "performance" | "vip"
  billingInterval  String?  // "monthly" | "annual"

  // Onboarding — basic (Phase 4)
  goal             String?  // "fat_loss" | "muscle" | "maintenance"
  daysPerWeek      Int?     // 1-7
  minutesPerSession Int?    // 15 | 20 | 30 | 45 | 60
  injuries         String?  // free-text limitations
  onboardedAt      DateTime?

  // Onboarding — extended intake (Milestone K)
  fullName          String?
  age               Int?
  height            String?
  currentWeight     String?
  bodyFat           String?
  timezone          String?
  occupation        String?

  // Training details
  yearsTraining     Int?
  currentSplit      String?
  favoriteLifts     String?
  weakBodyParts     String?
  equipmentAccess   String?  // "none" | "hotel" | "dumbbells" | "full_gym"
  sessionLength     Int?     // preferred session length in minutes

  // Nutrition details
  currentCalories   Int?
  proteinIntake     Int?
  mealsPerDay       Int?
  foodsEnjoy        String?
  foodsAvoid        String?
  appetiteLevel     String?  // "low" | "normal" | "high"
  weekendEating     String?
  alcoholIntake     String?
  supplements       String?

  // Lifestyle / recovery
  avgSleep          Float?
  stressLevel       String?  // "low" | "moderate" | "high"
  stepCount         Int?
  jobActivityLevel  String?  // "sedentary" | "light" | "moderate" | "active"
  travelFrequency   String?

  // Commitment
  fallOffCause      String?
  supportNeeded     String?
  success90Days     String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  checkIns         CheckIn[]
  reviews          Review[]
  programBlocks    ProgramBlock[]
  macroTargets     MacroTarget[]
}

model StripeEvent {
  id        String   @id // Stripe event id
  createdAt DateTime @default(now())
}

model CheckIn {
  id        String   @id @default(cuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id])
  date      DateTime @db.Date // one check-in per day

  // Quick daily logging (Phase 4 — preserved for backward compat)
  workout   Boolean  @default(false)
  meals     Int      @default(0) // 0-3 meals logged
  water     Boolean  @default(false)
  steps     Boolean  @default(false)
  note      String?  // optional "I missed because…"

  // Enhanced weekly check-in fields (Milestone L)
  // Body data
  avgWeight      Float?   // average weight this week
  waist          Float?   // waist measurement
  photoSubmitted Boolean  @default(false)
  frontPhotoUrl  String?  // link to front photo
  sidePhotoUrl   String?  // link to side photo
  backPhotoUrl   String?  // link to back photo

  // Adherence
  workoutsCompleted Int?   // how many workouts completed this week
  stepsAverage      Int?   // average daily steps
  calorieAdherence  Int?   // 1-10 scale
  proteinAdherence  Int?   // 1-10 scale
  sleepAverage      Float? // avg hours

  // Recovery / subjective scores (1-10)
  energyScore    Int?     // energy 1-10
  hungerScore    Int?     // hunger 1-10
  stressScore    Int?     // stress 1-10
  digestionScore Int?     // digestion 1-10
  recoveryScore  Int?     // overall recovery 1-10
  painNotes      String?  // pain/injury/soreness notes

  // Reflection
  biggestWin     String?  // biggest win this week
  biggestStruggle String? // biggest struggle this week
  helpNeeded     String?  // what help needed next week

  // Coach triage (set by coach or automation)
  coachStatus    String?  // "green" | "yellow" | "red" — set by coach
  coachResponse  String?  // coach's written response
  responseAt     DateTime? // when coach responded

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([memberId, date])
  @@index([memberId, date(sort: Desc)])
}

model Lead {
  id              String   @id @default(cuid())
  email           String   @unique
  quizAnswers     Json?    // stored quiz answers
  recommendedTier String?  // tier recommended by quiz engine
  source          String   @default("quiz") // "quiz" | "waitlist" | etc.
  capturedAt      DateTime @default(now())
  convertedAt     DateTime? // set when lead becomes a paying member

  // Nurture sequence tracking (Milestone J)
  lastNurtureStep Int      @default(0)  // 0=welcome sent, 1-4=drip emails
  lastNurtureAt   DateTime? // when the last nurture email was sent
  nurtureOptedOut Boolean  @default(false) // unsubscribe flag

  @@index([email])
}

model Application {
  id                  String   @id @default(cuid())
  email               String   @unique
  fullName            String
  phone               String?
  age                 Int?
  height              String?
  currentWeight       String?
  goal                String   // "fat_loss" | "muscle" | "maintenance"
  whyNow              String?
  trainingExperience  String?  // "beginner" | "intermediate" | "advanced"
  trainingFrequency   String?
  gymAccess           String?  // "none" | "hotel" | "dumbbells" | "full_gym"
  injuryHistory       String?
  nutritionStruggles  String?
  biggestObstacle     String?
  helpWithMost        String?
  preferredTier       String?  // "foundation" | "coaching" | "performance" | "vip"
  readyForStructure   Boolean  @default(false)
  budgetComfort       String?

  status              String   @default("pending") // "pending" | "approved" | "rejected"
  approvedAt          DateTime?
  paymentSent         Boolean  @default(false)
  convertedToMember   Boolean  @default(false)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status])
}

model Review {
  id             String    @id @default(cuid())
  memberId       String
  member         Member    @relation(fields: [memberId], references: [id])
  type           String    // "monthly" | "quarterly" | "form_review" | "live_call"
  dueDate        DateTime?
  completedDate  DateTime?
  summary        String?
  actionItems    String?   // JSON array of action item strings
  loomLink       String?
  followUpNeeded Boolean   @default(false)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([memberId])
}

/// Training program block — represents a mesocycle or training phase.
/// Follows backend.md Table 4 (Program Updates) + Section 11 (Programming).
model ProgramBlock {
  id              String    @id @default(cuid())
  memberId        String
  member          Member    @relation(fields: [memberId], references: [id])

  name            String    // e.g. "Hypertrophy Block 1", "Cut Phase A"
  status          String    @default("active") // "active" | "completed" | "upcoming"

  startDate       DateTime
  endDate         DateTime?

  // Programming details
  primaryGoal     String?   // "hypertrophy" | "strength" | "fat_loss" | "maintenance"
  split           String?   // "upper_lower" | "ppl" | "full_body" | "bro_split" | custom
  daysPerWeek     Int?      // 2-6
  progressionModel String?  // e.g. "double progression", "linear", "wave"
  deloadPlanned   Boolean   @default(false)
  deloadWeek      Int?      // which week is the deload (e.g. 4)

  // Content
  keyExercises    String?   // JSON array or comma-separated
  workoutNotes    String?   @db.Text // full workout plan or notes
  cardioTarget    String?   // e.g. "3x30min LISS + 10k steps"
  stepsTarget     Int?      // daily step target

  // Adjustments (filled when updating)
  adjustmentsMade String?   @db.Text
  adjustmentReason String?  @db.Text
  nextUpdateDate  DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([memberId])
  @@index([memberId, status])
}

/// Macro/nutrition targets — tracks calorie & macro prescriptions per client.
/// Follows backend.md Section 10 (Macros System).
model MacroTarget {
  id              String    @id @default(cuid())
  memberId        String
  member          Member    @relation(fields: [memberId], references: [id])

  status          String    @default("active") // "active" | "previous"
  effectiveDate   DateTime  // when these targets take effect

  // Targets
  calories        Int       // daily calorie target
  protein         Int       // grams
  fatsMin         Int?      // minimum fat grams
  carbs           Int?      // fill the rest
  stepsTarget     Int?      // daily steps
  hydrationTarget String?   // e.g. "3L" or "100 oz"

  // Adjustment context
  adjustmentReason String?  @db.Text // why this change was made
  previousCalories Int?     // what calories were before
  previousProtein  Int?     // what protein was before

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([memberId])
  @@index([memberId, status])
}

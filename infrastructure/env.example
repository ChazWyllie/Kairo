# ============================================
# Kairo Coaching — Environment Variables
# ============================================
# Copy to .env and fill in values.
# NEVER commit .env to version control.
# ============================================

# ===== App =====
APP_ENV=development
APP_URL=http://localhost:3000
PORT=3000

# ===== Database =====
# Example (Postgres):
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/kairo?schema=public

# ===== Stripe =====
STRIPE_SECRET_KEY=sk_live_or_test_***
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_***
STRIPE_PRICE_ID=price_***   # the $50/mo subscription price id

# ===== Email notifications =====
# Choose one provider later (Resend, Postmark, SendGrid, SES)
EMAIL_PROVIDER=resend
EMAIL_FROM="Kairo Coaching <no-reply@yourdomain.com>"
ADMIN_NOTIFY_EMAIL=you@yourdomain.com

# Provider-specific (example Resend)
RESEND_API_KEY=re_***

# ===== Security / Auth (if/when added) =====
# AUTH_SECRET=long_random_string

# ===== Error Tracking =====
SENTRY_DSN=
